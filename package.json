{
  "name": "prales",
  "private": true,
  "packageManager": "npm@11.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "db:generate": "npm run db:generate --workspace=packages/db",
    "db:migrate:local": "npm run db:migrate:local --workspace=apps/api",
    "seed:upload": "node scripts/upload-seed.mjs"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}